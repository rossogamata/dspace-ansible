# Managed by Ansible — do not edit manually.
# DSpace Nginx reverse proxy configuration
# Backend  (REST API): https://{{ nginx_backend_fqdn }}/server
# Frontend (Angular):  https://{{ nginx_frontend_fqdn }}/

# ── Redirect HTTP → HTTPS ─────────────────────────────────────────────────────
server {
    listen 80;
    listen [::]:80;
    server_name {{ nginx_backend_fqdn }}{% if nginx_frontend_fqdn != nginx_backend_fqdn %} {{ nginx_frontend_fqdn }}{% endif %};
    return 301 https://$host$request_uri;
}

# ── HTTPS: backend + frontend on the same domain ─────────────────────────────
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name {{ nginx_backend_fqdn }}{% if nginx_frontend_fqdn != nginx_backend_fqdn %} {{ nginx_frontend_fqdn }}{% endif %};

{% if nginx_use_letsencrypt %}
    ssl_certificate     /etc/letsencrypt/live/{{ nginx_backend_fqdn }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ nginx_backend_fqdn }}/privkey.pem;
    include             /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;
{% else %}
    ssl_certificate     {{ nginx_ssl_cert }};
    ssl_certificate_key {{ nginx_ssl_key }};
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;
{% endif %}

    proxy_set_header Host               $host;
    proxy_set_header X-Real-IP          $remote_addr;
    proxy_set_header X-Forwarded-For    $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto  https;
    proxy_set_header X-Forwarded-Host   $host;
    proxy_set_header X-Forwarded-Port   443;

    client_max_body_size {{ max_upload_size }};

    # DSpace REST API
    location /server {
        proxy_pass http://127.0.0.1:{{ nginx_backend_port }}/server;
        proxy_read_timeout 300;
        proxy_send_timeout 300;
        proxy_connect_timeout 60;
    }

    # Block direct access to internal services
    location ~* ^/(solr|pgadmin)/ {
        return 403;
    }

    # Angular SSR frontend (catch-all)
    location / {
        proxy_pass http://127.0.0.1:{{ nginx_frontend_port }}/;
        proxy_read_timeout 120;
        proxy_send_timeout 120;
        proxy_http_version 1.1;
        proxy_set_header Upgrade    $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}

{% if nginx_frontend_fqdn != nginx_backend_fqdn %}
# ── Separate frontend domain ───────────────────────────────────────────────────
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name {{ nginx_frontend_fqdn }};

{% if nginx_use_letsencrypt %}
    ssl_certificate     /etc/letsencrypt/live/{{ nginx_backend_fqdn }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ nginx_backend_fqdn }}/privkey.pem;
    include             /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;
{% else %}
    ssl_certificate     {{ nginx_ssl_cert }};
    ssl_certificate_key {{ nginx_ssl_key }};
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;
{% endif %}

    proxy_set_header Host               $host;
    proxy_set_header X-Real-IP          $remote_addr;
    proxy_set_header X-Forwarded-For    $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto  https;
    proxy_set_header X-Forwarded-Host   $host;
    proxy_set_header X-Forwarded-Port   443;

    client_max_body_size {{ max_upload_size }};

    location / {
        proxy_pass http://127.0.0.1:{{ nginx_frontend_port }}/;
        proxy_read_timeout 120;
        proxy_send_timeout 120;
        proxy_http_version 1.1;
        proxy_set_header Upgrade    $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
{% endif %}
